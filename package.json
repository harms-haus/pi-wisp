{
  "name": "pi-wisp",
  "version": "0.1.0",
  "description": "Multi-agent workflow orchestrator extension for the pi coding agent",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src/**/*.ts",
    "!src/__tests__/**",
    "skills/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills/wisp-authoring"
    ]
  },
  "author": "harms-haus",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "workflow",
    "multi-agent"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "pre-commit-check": "npm run format:check && npm run lint && npm run typecheck",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run pre-commit-check"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "dependencies": {
    "tree-kill": "^1.2.2",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typebox": "*",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
